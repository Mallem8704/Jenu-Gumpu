<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.JenuGumpu" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/honey_primary</item>
        <item name="colorOnPrimary">@color/forest_dark</item>
        <item name="colorSecondary">@color/honey_secondary</item>
        <item name="android:windowBackground">@color/forest_dark</item>
        <item name="android:statusBarColor">@color/forest_dark</item>
    </style>

    <style name="Theme.JenuGumpu.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/forest_dark</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_home</item>
        <item name="postSplashScreenTheme">@style/Theme.JenuGumpu</item>
    </style>
</resources>
