<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/forest_dark">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/grading"
            android:textColor="@color/white"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="20dp"/>

        <!-- Input Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            android:backgroundTint="@color/forest_mid"
            app:strokeWidth="1dp"
            app:strokeColor="@color/glass_border"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Floral Source"
                    android:textColor="@color/beeswax"
                    android:alpha="0.5"
                    android:textSize="12sp"
                    android:layout_marginBottom="8dp"/>

                <Spinner
                    android:id="@+id/spinnerFloral"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    android:backgroundTint="@color/honey_primary"/>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Moisture Level (%)"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    app:hintTextColor="@color/honey_primary"
                    app:boxStrokeColor="@color/honey_primary"
                    android:layout_marginBottom="20dp">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etMoisture"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/white"
                        android:inputType="numberDecimal"/>
                </com.google.android.material.textfield.TextInputLayout>

                <Button
                    android:id="@+id/btnCheck"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="Check Grade"
                    android:textAllCaps="false"
                    android:textStyle="bold"
                    app:cornerRadius="16dp"
                    android:backgroundTint="@color/honey_primary"
                    android:textColor="@color/forest_dark"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Result Card (Hidden by default) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            android:backgroundTint="#11FFFFFF"
            app:strokeWidth="1dp"
            app:strokeColor="#33FFFFFF"
            android:layout_marginBottom="32dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">
                    <TextView
                        android:id="@+id/tvResultGrade"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Premium"
                        android:textColor="@color/moss_green"
                        android:textSize="24sp"
                        android:textStyle="black"/>
                    <TextView
                        android:id="@+id/tvStars"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⭐⭐⭐"
                        android:textSize="20sp"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvResultDesc"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="16.5% moisture — Excellent quality."
                    android:textColor="@color/beeswax"
                    android:alpha="0.6"
                    android:textSize="14sp"
                    android:layout_marginTop="4dp"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#1AFFFFFF"
                    android:layout_marginVertical="20dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="✨" android:textSize="16sp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="AI RECOMMENDATION"
                        android:textColor="@color/honey_primary"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1"/>
                </LinearLayout>

                <ProgressBar
                    android:id="@+id/pbAI"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:visibility="gone"
                    android:indeterminateTint="@color/honey_primary"/>

                <TextView
                    android:id="@+id/tvAIRecommendation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Processing..."
                    android:textColor="@color/beeswax"
                    android:textSize="14sp"
                    android:lineSpacingExtra="4dp"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
