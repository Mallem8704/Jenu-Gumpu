<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/forest_dark"
    android:padding="20dp">

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/stock"
        android:textColor="@color/white"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Total Stock Card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardTotalStock"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        android:backgroundTint="@color/forest_mid"
        app:strokeWidth="1dp"
        app:strokeColor="@color/honey_primary"
        app:layout_constraintTop_toBottomOf="@id/tvTitle">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="24dp">
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TOTAL COLLECTIVE STOCK"
                android:textColor="@color/beeswax"
                android:alpha="0.5"
                android:textSize="10sp"
                android:letterSpacing="0.1"/>

            <TextView
                android:id="@+id/tvTotalStock"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="250.0"
                android:textColor="@color/honey_primary"
                android:textSize="48sp"
                android:textStyle="black"
                android:layout_marginTop="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="KILOGRAMS (KG)"
                android:textColor="@color/honey_primary"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginTop="-4dp"/>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/tvBatchTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Batch-wise Stock"
        android:textColor="@color/beeswax"
        android:alpha="0.7"
        android:textSize="14sp"
        android:textStyle="bold"
        android:layout_marginTop="24dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/cardTotalStock"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvBatches"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvBatchTitle"
        tools:listitem="@layout/item_harvest" />

</androidx.constraintlayout.widget.ConstraintLayout>
